{
  "$schema": "https://opencode.ai/config.json",
  // Theme configuration
  "theme": "catppuccin-macchiato",
  "autoupdate": true,
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "us-west-2",
        "profile": "programmatic-ai"
      }
    }
  },
  "mcp": {
    "asana": {
      "type": "remote",
      "url": "https://mcp.asana.com/v2/mcp",
      //"enabled": true,
      "oauth": {
        "clientId": "1216135129131473",
        "clientSecret": "c4f91e3487a1225d1363e7d57322dd0f",
        "scope": "tools:read tools:execute"
      }
    }
  },
  "permission": {
    "edit": {
      "*": "ask",
      "*.md": "allow",
      "*.py": "ask"
    },
    "bash": {
      "rm *": "deny",
      "*": "ask",
      "cat *": "allow",
      "cat *.env": "deny",
      "tail *": "allow",
      "tail *.env": "deny",
      "ls *": "allow",
      "rg *": "allow",
      "wc *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "git blame *": "allow",
      "git branch*": "allow",
      "git branch -d*": "ask",
      "git branch -D*": "ask",
      "git branch --delete*": "ask",
      "git branch -m*": "ask",
      "git branch -M*": "ask",
      "git branch --move*": "ask",
      "git branch -c*": "ask",
      "git branch -C*": "ask",
      "git branch --copy*": "ask",
      "git diff *": "allow",
      "git grep *": "allow",
      "git log *": "allow",
      "git merge-base": "allow",
      "git remote show origin": "allow",
      "git rev-list": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "uv run pytest*": "allow",
      "uv run pyright*": "allow",
      "find *": "allow",
      "sort *": "allow",
      "echo *": "allow",
      "echo $*": "ask",
      "python scan_claimfile.py *": "allow",
      "python medscan_claimfile.py *": "allow",
      "npm run*": "allow",
      "npm test": "allow",
      "python -m unittest*": "allow"
    },
    "webfetch": "ask",
    "doom_loop": "ask",
    "external_directory": "ask",
    // Asana MCP (remote server "asana"): gate every destructive/mutating tool.
    // Read-only tools (asana_get_*, asana_search_*, *_preview) stay ungated.
    "asana_create_tasks": "ask",
    "asana_create_project": "ask",
    "asana_create_project_status_update": "ask",
    "asana_add_comment": "ask",
    "asana_update_tasks": "ask",
    "asana_delete_task": "ask"
  },
  "agent": {
    "build": {
      "permission": {
        "external_directory": {
          "/tmp/loader-builder/**": "allow"
        }
      }
    },
    "plan": {
      "permission": {
        "edit": {
          "*": "deny",
          "*.md": "allow",
          "*.py": "ask"
        }
      }
    }
  }
}
