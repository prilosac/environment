{
  "$schema": "https://opencode.ai/config.json",
  // Theme configuration
  "theme": "catppuccin-macchiato",
  "autoupdate": true,
  "mcp": {
    "asana": {
      "type": "remote",
      "url": "https://mcp.asana.com/v2/mcp",
      //"enabled": true,
      "oauth": {
        "clientId": "1216135129131473",
        "clientSecret": "c4f91e3487a1225d1363e7d57322dd0f",
        "scope": "tools:read tools:execute"
      }
    }
  },
  "permission": {
    "edit": {
      "*": "ask",
      "*.md": "allow",
      "*.py": "ask"
    },
    "bash": {
      "rm *": "deny",
      "*": "ask",
      "ls *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "git branch --show-current": "allow",
      "git branch --list": "allow",
      "git branch -a": "allow",
      "git remote show origin": "allow",
      "uv run pytest*": "allow",
      "find *": "allow",
      "sort *": "allow",
      "echo *": "allow",
      "echo $*": "ask",
      "python scan_claimfile.py *": "allow",
      "python medscan_claimfile.py *": "allow"
    },
    "webfetch": "ask",
    "doom_loop": "ask",
    "external_directory": "ask",
    // Asana MCP (remote server "asana"): gate every destructive/mutating tool.
    // Read-only tools (asana_get_*, asana_search_*, *_preview) stay ungated.
    "asana_create_tasks": "ask",
    "asana_create_project": "ask",
    "asana_create_project_status_update": "ask",
    "asana_add_comment": "ask",
    "asana_update_tasks": "ask",
    "asana_delete_task": "ask"
  },
  "agent": {
    "build": {
      "permission": {
        "external_directory": {
          "/tmp/loader-builder/**": "allow"
        }
      }
    },
    "plan": {
      "permission": {
        "edit": {
          "*": "deny",
          "*.md": "allow",
          "*.py": "ask"
        }
      }
    }
  }
}
